# =========================================================================
# TEMPLATE KONFIGURASI ENVIRONMENT VARIABLES (.env)
# =========================================================================

# 1. Konfigurasi Koneksi Database (Ganti dengan detail database aaPanel Anda)
# Format MySQL: mysql://user_db:password_db@host:port/nama_db
# Contoh: mysql://user_rekabkelas:SecretPass123!@127.0.0.1:3306/db_rekabkelas
DATABASE_URL="mysql://username_db_aapanel:password_db_aapanel@127.0.0.1:3306/nama_database_aapanel"

# 2. Port & Environment Server Node.js
PORT=3000
NODE_ENV=production

# 3. Kredensial API Simulasi WhatsApp Gateway (Opsional jika ingin dihubungkan ke penyedia nyata seperti Fonnte/Twilio)
WA_API_TOKEN="api_token_anda_disini"
WA_GATEWAY_URL="https://api.fonnte.com/send"
